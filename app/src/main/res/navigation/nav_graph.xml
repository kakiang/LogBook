<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph.xml"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.hervekakiang.logbook.dashboard.DashboardFragment"
        android:label="Dashboard">
        <action
            android:id="@+id/action_dashboard_to_ajouterUeFragment"
            app:destination="@id/ajouterUeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/ueListFragment"
        android:name="com.hervekakiang.logbook.ue.UeListFragment"
        android:label="Unités d'Enseignement">

        <action
            android:id="@+id/action_ueListFragment_to_ueDetailFragment"
            app:destination="@id/ueDetailFragment" />

    </fragment>

    <fragment
        android:id="@+id/matiereListFragment"
        android:name="com.hervekakiang.logbook.matiere.MatiereListFragment"
        android:label="Matières" />

    <fragment
        android:id="@+id/seanceListFragment"
        android:name="com.hervekakiang.logbook.seance.SeanceListFragment" />

    <fragment
        android:id="@+id/ueDetailFragment"
        android:name="com.hervekakiang.logbook.ue.UeDetailFragment"
        android:label="{fragmentTitle}">

        <argument
            android:name="fragmentTitle"
            app:argType="string" />

        <action
            android:id="@+id/action_to_ajouterMatiereFragment"
            app:destination="@id/ajouterMatiereFragment" />
    </fragment>

    <fragment
        android:id="@+id/matiereDetailFragment"
        android:name="com.hervekakiang.logbook.matiere.MatiereDetailFragment"
        android:label="{fragmentTitle}">

        <argument
            android:name="fragmentTitle"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/seanceDetailFragment"
        android:name="com.hervekakiang.logbook.seance.SeanceDetailFragment"
        android:label="Seance Details"/>


    <fragment
        android:id="@+id/ajouterUeFragment"
        android:name="com.hervekakiang.logbook.ue.AddUeFragment"
        android:label="Nouvelle UE"
        tools:layout="@layout/fragment_add_ue">
        <argument
            android:name="ueId"
            app:argType="integer"
            android:defaultValue="-1"/>
        <argument
            android:name="isEditing"
            app:argType="boolean"
            android:defaultValue="false"/>
    </fragment>

    <fragment
        android:id="@+id/ajouterMatiereFragment"
        android:name="com.hervekakiang.logbook.matiere.AjouterMatiereFragment"
        android:label="Nouvelle matière"
        tools:layout="@layout/fragment_ajouter_matiere">
        <argument
            android:name="selectedUeId"
            app:argType="integer"
            android:defaultValue="-1" />
        <argument
            android:name="matiereId"
            app:argType="integer"
            android:defaultValue="-1" />
        <argument
            android:name="isEditing"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/ajouterSeanceFragment"
        android:name="com.hervekakiang.logbook.seance.AjouterSeanceFragment"
        android:label="Nouvelle Seance"
        tools:layout="@layout/fragment_ajouter_seance">
        <argument
            android:name="selectedMatiereId"
            app:argType="integer"
            android:defaultValue="-1"/>
        <argument
            android:name="seanceId"
            app:argType="integer"
            android:defaultValue="-1"/>
        <argument
            android:name="isEditing"
            app:argType="boolean"
            android:defaultValue="false"/>

        <action
            android:id="@+id/action_create_to_seanceDetailFragment"
            app:destination="@id/seanceDetailFragment"
            app:popUpTo="@id/ajouterSeanceFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_update_to_seanceDetailFragment"
            app:destination="@id/seanceDetailFragment"
            app:popUpTo="@id/seanceDetailFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>